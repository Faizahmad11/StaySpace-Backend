# Backend Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# MongoDB Connection (use your own MongoDB Atlas URI)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Email Configuration (Gmail App Password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
BRAND_NAME=StaySpace
CONTACT_PHONE=+92 327 5500115
WEBSITE_URL=https://stayspace.com

# JWT Configuration
JWT_SECRET=your-very-secure-random-string-at-least-32-characters-long-here
JWT_EXPIRES_IN=7d

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Password Requirements
MIN_PASSWORD_LENGTH=8
